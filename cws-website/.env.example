# Apify API token (https://console.apify.com/account/integrations)
# Used by /api/youtube to scrape the CWS YouTube channel via the
# `streamers~youtube-scraper` actor. Replaces the previous YouTube Data
# API v3 integration. If unset, the route serves the static fallback.
APIFY_API_KEY=your_apify_api_key_here

# Optional override for the channel URL fed into the Apify actor
# YOUTUBE_CHANNEL_URL=https://www.youtube.com/@CoffeeWithStoryphiler_CWS/videos

# Used by the contact form (form submits to this URL)
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id
NEXT_PUBLIC_WHATSAPP_NUMBER=919XXXXXXXXX
